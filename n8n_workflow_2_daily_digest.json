    {
      "parameters": {
        "jsCode": "const items = $('Get Unsent Queue Items').all();\n\n// Her item için ayrı ayrı döndür, title boş olanları atla\nconst result = items\n  .filter(item => item.json['Title'] && item.json['Title'] !== '')\n  .map(item => ({\n    json: {\n      matchValue: item.json['Title'],\n      opportunityId: item.json['Opportunity ID']\n    }\n  }));\n\nif (result.length === 0) {\n  return [{ json: { matchValue: 'NO_MATCH', opportunityId: '' } }];\n}\n\nreturn result;"
      },
