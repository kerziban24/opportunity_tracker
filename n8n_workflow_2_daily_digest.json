    {
      "parameters": {
        "jsCode": "const items = $('Get Unsent Queue Items').all();\nconst today = new Date().toLocaleDateString('tr-TR', { \n  weekday: 'long', \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric' \n});\n\nif (!items || items.length === 0) {\n  return [{ json: { html: '<p>Bugün yeni fırsat bulunamadı.</p>', count: 0, today } }];\n}\n\nlet rows = '';\nitems.forEach(item => {\n  const o = item.json;\n  const title = o['Title'] || o['title'] || 'Başlık yok';\n  const deadline = o['Deadline'] || o['deadline'] || 'Belirtilmemiş';\n  const type = o['Type'] || o['type'] || '';\n  const link = o['Link'] || o['link'] || '#';\n\n  rows += `\n    <tr>\n      <td style=\"padding:12px;border-bottom:1px solid #eee\">\n        <strong>${title}</strong><br>\n        <small style=\"color:#888\">${type}</small>\n      </td>\n      <td style=\"padding:12px;border-bottom:1px solid #eee;color:#e74c3c\">\n        ${deadline}\n      </td>\n      <td style=\"padding:12px;border-bottom:1px solid #eee\">\n        <a href=\"${link}\" style=\"background:#6c63ff;color:white;padding:6px 12px;border-radius:6px;text-decoration:none;font-size:13px\">Başvur →</a>\n      </td>\n    </tr>`;\n});\n\nconst html = `\n<html><body style=\"font-family:sans-serif;max-width:680px;margin:auto\">\n  <div style=\"background:#1a1a2e;padding:28px;text-align:center;border-radius:12px 12px 0 0\">\n    <h1 style=\"color:white;margin:0;font-size:22px\">🎓 Günlük Fırsat Özeti</h1>\n    <p style=\"color:rgba(255,255,255,0.6);margin:8px 0 0\">${today}</p>\n  </div>\n  <div style=\"background:#6c63ff;padding:10px;text-align:center\">\n    <span style=\"color:white;font-weight:600\">${items.length} yeni fırsat profilinizle eşleşti</span>\n  </div>\n  <div style=\"padding:24px;background:white\">\n    <table style=\"width:100%;border-collapse:collapse\">\n      <thead>\n        <tr style=\"background:#f8f9ff\">\n          <th style=\"padding:10px;text-align:left;font-size:12px;color:#888;text-transform:uppercase\">Fırsat</th>\n          <th style=\"padding:10px;text-align:left;font-size:12px;color:#888;text-transform:uppercase\">Son Tarih</th>\n          <th style=\"padding:10px;text-align:left;font-size:12px;color:#888;text-transform:uppercase\">Link</th>\n        </tr>\n      </thead>\n      <tbody>${rows}</tbody>\n    </table>\n  </div>\n  <div style=\"background:#f8f9ff;padding:16px;text-align:center;border-radius:0 0 12px 12px\">\n    <p style=\"color:#aaa;font-size:12px;margin:0\">Fırsat Takip Sistemi · n8n + Gemini AI</p>\n  </div>\n</body></html>`;\n\nreturn [{ json: { html, count: items.length, today } }];"
      },
