        "jsCode": "const allRows = $input.all();\n\nconst unsent = allRows.filter(row => {\n  const sent = row.json['Sent?'];\n  return sent === false || \n         sent === 'FALSE' || \n         sent === 'false' || \n         sent === 'False' ||\n         sent === '' ||\n         sent === undefined ||\n         sent === null;\n});\n\nreturn unsent;"
