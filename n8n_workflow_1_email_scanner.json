        "jsCode": "const profileRows = $input.all();\n\nconst profile = {};\n\nprofileRows.forEach(row => {\n\n  profile[row.json.Field] = row.json.Value;\n\n});\n\nreturn [{ json: { userProfile: profile } }];\n"
