    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateContent?key=AIzaSyB2b_w-pXoC83tI180Z1Ew2MuYNtRzfuBg",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": "AIzaSyB2b_w-pXoC83tI180Z1Ew2MuYNtRzfuBg"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\"contents\":[{\"parts\":[{\"text\":\"Extract opportunity info from this email. Return ONLY a JSON object, no markdown, no explanation.\\n\\nIf this email is NOT about a scholarship, internship, fellowship, grant, or competition, return exactly:\\n{\\\"classification\\\":\\\"irrelevant\\\"}\\n\\nIf it IS an opportunity, return exactly this structure:\\n{\\\"classification\\\":\\\"scholarship\\\",\\\"title\\\":\\\"Full name of opportunity\\\",\\\"organization\\\":\\\"Organization name\\\",\\\"type\\\":\\\"scholarship\\\",\\\"deadline\\\":\\\"2025-06-30\\\",\\\"location\\\":\\\"Country or city\\\",\\\"eligibility\\\":\\\"Who can apply\\\",\\\"link\\\":\\\"https://apply-url.com\\\",\\\"is_relevant_to_user\\\":true,\\\"tags\\\":[\\\"funded\\\",\\\"Europe\\\"]}\\n\\nRules:\\n- type must be one of: scholarship, internship, fellowship, grant, competition\\n- deadline must be YYYY-MM-DD format or null\\n- is_relevant_to_user is true unless clearly restricted to a country or group that excludes a Turkish undergraduate STEM student\\n- link: use the most direct application URL found, or null\\n- Return ONLY the JSON. No text before or after.\\n\\nEMAIL SUBJECT: {{ $('Generate Email Hash').first().json.subject }}\\nEMAIL BODY: {{ $('Generate Email Hash').first().json.bodyShort }}\"}]}],\"generationConfig\":{\"temperature\":0,\"maxOutputTokens\":2000,\"candidateCount\":1}}",
        "options": {}
      },
      "name": "Call Gemini AI",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -1072,
        -64
      ],
      "id": "342877b6-40ad-4ccd-a8c5-48d6fcf236f8",
      "typeVersion": 4.4,
      "retryOnFail": false,
      "waitBetweenTries": 5000,
      "maxTries": 5,
      "notes": "SETUP: Replace YOUR_GEMINI_API_KEY_HERE with your key from Google AI Studio."
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst parsedItems = items.map((item) => {\n  let text = item?.json?.candidates[0]?.content?.parts[0]?.text || '';\n  \n  // Gemini'nin eklediği ```json ve ``` işaretlerini temizle\n  text = text.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n  \n  try {\n    const parsed = JSON.parse(text);\n    return { json: parsed };\n  } catch(e) {\n    return { json: { classification: 'irrelevant', err: e.message } };\n  }\n});\nreturn parsedItems;"
      },
