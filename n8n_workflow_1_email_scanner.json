    {
      "parameters": {
        "jsCode": "const subject = $input.item.json.subject || '';\nconst sender = $input.item.json.from || '';\nconst combined = (subject + sender).toLowerCase();\n\nlet hash = 0;\nfor (let i = 0; i < combined.length; i++) {\n  const char = combined.charCodeAt(i);\n  hash = ((hash << 5) - hash) + char;\n  hash = hash & hash;\n}\nconst emailHash = Math.abs(hash).toString(16);\n\nconst rawBody = $input.item.json.text || $input.item.json.snippet || $input.item.json.body || '';\n\nreturn [{\n  json: {\n    ...$input.item.json,\n    emailHash: emailHash,\n    bodyShort: rawBody.substring(0, 800)\n  }\n}];"
      },
